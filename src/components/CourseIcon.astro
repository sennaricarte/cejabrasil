---
import { courseIconLabels, getCourseIconType } from '../utils/courseIcons';

interface Props {
	imageKey: string;
	title: string;
	class?: string;
}

const { imageKey, title, class: className = 'h-24 w-24' } = Astro.props;
const iconType = getCourseIconType(imageKey);
const label = `${courseIconLabels[iconType]} — ${title}`;
---

<svg
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.75"
	stroke-linecap="round"
	stroke-linejoin="round"
	class={className}
	role="img"
	aria-label={label}
>
	{iconType === 'administrativo' && (
		<>
			<rect x="4" y="3" width="16" height="18" rx="2" />
			<path d="M8 7h8M8 11h8M8 15h5" />
		</>
	)}
	{iconType === 'varejo' && (
		<>
			<path d="M4 7h16l-1.2 11H5.2L4 7Z" />
			<path d="M9 7V5a3 3 0 0 1 6 0v2" />
		</>
	)}
	{iconType === 'contact-center' && (
		<>
			<path d="M4 11a8 8 0 0 1 16 0" />
			<path d="M8 18h8M12 11v7" />
			<rect x="3" y="11" width="4" height="6" rx="1" />
			<rect x="17" y="11" width="4" height="6" rx="1" />
		</>
	)}
	{iconType === 'teleprocessamento' && (
		<>
			<circle cx="12" cy="12" r="3" />
			<path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M16.9 16.9l2.1 2.1M4.9 19.1l2.1-2.1M16.9 7.1l2.1-2.1" />
		</>
	)}
	{iconType === 'producao' && (
		<>
			<path d="M3 21h18" />
			<path d="M6 21V9l4-3v15M14 21V5l4 3v13" />
			<path d="M10 9h4" />
		</>
	)}
	{iconType === 'saude' && (
		<>
			<path d="M12 21s-7-4.4-7-10a4 4 0 0 1 7-2 4 4 0 0 1 7 2c0 5.6-7 10-7 10Z" />
			<path d="M12 8v6M9 11h6" />
		</>
	)}
	{iconType === 'alimentacao' && (
		<>
			<path d="M6 4v8M8 4v8M6 12v8" />
			<path d="M14 4c2 2 2 6 0 8v8" />
		</>
	)}
	{iconType === 'manutencao' && (
		<path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L4 17l3 3 5.3-5.3a4 4 0 0 0 5.4-5.4l-2.1 2.1-3.3-3.3 2.1-2.1Z" />
	)}
	{iconType === 'frentista' && (
		<>
			<path d="M6 20h12" />
			<path d="M8 20V8h8v12" />
			<path d="M10 8V5h4v3" />
			<path d="M12 12v4" />
		</>
	)}
	{iconType === 'telecom' && (
		<>
			<path d="M4 10v4M8 8v8M12 5v14M16 8v8M20 10v4" />
			<path d="M2 20h20" />
		</>
	)}
	{iconType === 'jardineiro' && (
		<>
			<path d="M12 21V11" />
			<path d="M12 11c-4-3-6-7-4-9s6 0 4 9Z" />
			<path d="M12 11c4-3 6-7 4-9s-6 0-4 9Z" />
			<path d="M5 21h14" />
		</>
	)}
</svg>
