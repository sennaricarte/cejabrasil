---
import CourseIcon from './CourseIcon.astro';

interface Props {
	title: string;
	hours: string;
	description: string;
	imageKey: string;
	detailHref?: string;
}

const { title, hours, description, imageKey, detailHref = '#' } = Astro.props;
const isLongTitle = title.length > 58;
---

<article class="group flex h-full flex-col overflow-hidden rounded-[2rem] border border-ceja-blue-light bg-white p-5 shadow-sm transition-shadow duration-300 hover:shadow-md">
	<div class="relative">
		<div class="absolute right-3 top-3 z-10 inline-flex w-fit rounded-full bg-white/90 px-3 py-1 text-xs font-bold uppercase tracking-wide text-ceja-blue-dark shadow-sm">
			{hours}
		</div>
		<div class="flex h-52 items-center justify-center overflow-hidden rounded-[2rem_2rem_2.8rem_1.4rem] bg-gradient-to-br from-ceja-blue-light via-white to-ceja-green-light/40">
			<div class="flex h-32 w-32 items-center justify-center rounded-full bg-white/80 text-ceja-header shadow-inner transition duration-500 group-hover:scale-110 group-hover:text-ceja-blue">
				<CourseIcon imageKey={imageKey} title={title} class="h-16 w-16" />
			</div>
		</div>
		<div class="pointer-events-none absolute -bottom-3 left-4 h-6 w-20 rounded-[55%_45%_60%_40%] bg-ceja-orange/35"></div>
	</div>

	<div class="mt-6 flex flex-1 flex-col">
		<h3
			class:list={[
				'line-clamp-2 min-h-[3.4rem] font-bold leading-tight text-ceja-blue-dark',
				isLongTitle ? 'text-xl' : 'text-2xl',
			]}
		>
			{title}
		</h3>
		<p class="mt-4 text-sm leading-relaxed text-ceja-muted">
			{description}
		</p>
		<a
			href={detailHref}
			class="mt-6 inline-flex w-fit items-center rounded-full border border-ceja-blue-dark bg-transparent px-4 py-2 text-xs font-semibold uppercase tracking-wide text-ceja-blue-dark transition-colors duration-300 hover:bg-ceja-blue-dark hover:text-white"
		>
			Ver Detalhes
		</a>
	</div>
</article>
