---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import dados from '../data/jovem-aprendiz.json';
import heroJovemAprendiz from '../assets/jovem-aprendiz/hero-jovem-aprendiz.png';
import diferencialJovemAprendiz from '../assets/jovem-aprendiz/diferencial-jovem-aprendiz.png';
import cardVagas from '../assets/vagas/card-vagas.jpg';
---

<Layout
	title="Programa Jovem Aprendiz CEJA Brasil | Formação de Jovens Talentos"
	description="O CEJA Brasil atua na captação, seleção, contratação, formação e acompanhamento pedagógico de jovens aprendizes, com total conformidade à Lei da Aprendizagem (Lei nº 10.097/2000)."
	keywords={dados.seoKeywords}
>
	<section class="relative overflow-hidden bg-white py-20">
		<div class="pointer-events-none absolute -left-10 top-16 h-24 w-24 rounded-full bg-ceja-blue/15"></div>
		<div class="pointer-events-none absolute right-8 top-20 h-20 w-20 rounded-[45%_55%_50%_50%] bg-ceja-orange/35"></div>

		<div class="mx-auto grid w-full max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Entidade Qualificadora</p>
				<h1 class="mt-4 text-4xl font-black leading-tight text-ceja-blue-dark sm:text-5xl lg:text-6xl">
					{dados.hero.titulo}
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-relaxed text-ceja-muted">
					{dados.hero.subtitulo}
				</p>
				<div class="mt-9 flex flex-wrap items-center gap-4">
					<a
						href="#contratar-aprendiz"
						class="inline-flex rounded-full bg-ceja-orange px-7 py-3 text-base font-semibold text-white transition hover:brightness-105"
					>
						{dados.hero.ctaEmpresa}
					</a>
					<a
						href="/vagas"
						class="inline-flex rounded-full border-2 border-ceja-blue px-7 py-3 text-base font-semibold text-ceja-blue transition hover:bg-ceja-blue hover:text-white"
					>
						{dados.hero.ctaJovem}
					</a>
				</div>
			</div>

			<div class="relative mx-auto w-full max-w-xl">
				<div class="pointer-events-none absolute -left-6 top-6 h-14 w-24 rounded-[60%_40%_45%_55%] bg-ceja-blue/20"></div>
				<div class="pointer-events-none absolute right-3 -bottom-3 h-16 w-28 rounded-[35%_65%_50%_50%] bg-ceja-orange/40"></div>
				<div class="overflow-hidden rounded-[2.8rem] border-8 border-white bg-white shadow-[0_30px_60px_-28px_rgba(15,74,110,0.28)]">
					<Image
						src={heroJovemAprendiz}
						alt="Jovem aprendiz em traje profissional com postura confiante em ambiente corporativo"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						class="h-[420px] w-full object-cover"
					/>
				</div>
				<div class="absolute -bottom-8 left-4 hidden h-36 w-44 overflow-hidden rounded-[1.6rem] border-4 border-white bg-white shadow-xl sm:block">
					<Image
						src={cardVagas}
						alt="Jovem em ambiente educacional durante formação profissional"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						class="h-full w-full object-cover"
					/>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-ceja-surface py-20 sm:py-24" aria-labelledby="apresentacao-jovem-aprendiz">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="overflow-hidden rounded-[2.5rem] border border-ceja-blue-light bg-white shadow-sm">
				<div class="grid gap-10 p-8 sm:p-10 lg:grid-cols-[1fr_1.1fr] lg:items-center lg:p-12">
					<div>
						<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Sobre o programa</p>
						<h2 id="apresentacao-jovem-aprendiz" class="mt-3 text-3xl font-black leading-tight text-ceja-blue-dark sm:text-4xl">
							{dados.apresentacao.titulo}
						</h2>
						<p class="mt-4 text-lg font-semibold leading-snug text-ceja-blue">
							{dados.apresentacao.subtitulo}
						</p>
					</div>

					<div class="space-y-5 text-base leading-relaxed text-ceja-muted">
						{
							dados.apresentacao.paragrafos.map((paragrafo) => (
								<p>{paragrafo}</p>
							))
						}
					</div>
				</div>

				<div class="border-t border-ceja-blue-light bg-ceja-blue-light/40 px-8 py-6 sm:px-12">
					<ul class="flex flex-wrap gap-2" aria-label="Temas do programa jovem aprendiz">
						{
							[
								'Lei da Aprendizagem',
								'Contratação de aprendizes',
								'Inclusão produtiva',
								'Capacitação profissional',
								'Formação de talentos',
								'Desenvolvimento profissional',
							].map((tag) => (
								<li class="rounded-full border border-ceja-blue/20 bg-white px-4 py-1.5 text-xs font-semibold text-ceja-blue-dark">
									{tag}
								</li>
							))
						}
					</ul>

					<div class="mt-6 flex flex-wrap gap-4">
						<a
							href="/empresas"
							class="inline-flex rounded-full bg-ceja-orange px-7 py-3 text-sm font-extrabold uppercase tracking-wide text-white transition hover:brightness-105"
						>
							{dados.apresentacao.ctaProposta}
						</a>
						<a
							href="/contato"
							class="inline-flex rounded-full border-2 border-ceja-blue bg-white px-7 py-3 text-sm font-extrabold uppercase tracking-wide text-ceja-blue transition hover:bg-ceja-blue hover:text-white"
						>
							{dados.apresentacao.ctaEspecialista}
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-white py-20">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Como funciona</p>
				<h2 class="mt-3 text-3xl font-bold text-ceja-blue-dark sm:text-4xl">Do Primeiro Contato ao Acompanhamento Contínuo</h2>
			</div>

			<div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
				{
					dados.etapas.map((etapa, index) => (
						<article class="rounded-[2rem] border border-ceja-blue-light bg-white p-6 shadow-sm">
							<span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-ceja-blue text-sm font-bold text-white">
								{index + 1}
							</span>
							<h3 class="mt-4 text-xl font-bold text-ceja-blue-dark">{etapa.titulo}</h3>
							<p class="mt-3 text-sm leading-relaxed text-ceja-muted">{etapa.descricao}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-ceja-surface py-20">
		<div class="mx-auto grid w-full max-w-7xl gap-6 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
			<article class="rounded-[2rem] border-2 border-ceja-blue bg-white p-8 shadow-sm">
				<h2 class="text-2xl font-bold text-ceja-blue-dark">Para Empresas</h2>
				<ul class="mt-5 space-y-3 text-sm leading-relaxed text-ceja-muted">
					{
						dados.beneficiosEmpresa.map((item) => (
							<li>• {item}</li>
						))
					}
				</ul>
				<a
					href="/empresas"
					class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-ceja-blue transition hover:text-ceja-orange"
				>
					Soluções para empresas
					<span aria-hidden="true">→</span>
				</a>
			</article>

			<article class="rounded-[2rem] bg-ceja-header p-8 text-white shadow-sm">
				<h2 class="text-2xl font-bold">Para Jovens</h2>
				<ul class="mt-5 space-y-3 text-sm leading-relaxed text-ceja-blue-light">
					{
						dados.beneficiosJovem.map((item) => (
							<li>• {item}</li>
						))
					}
				</ul>
				<a
					href="/vagas"
					class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-ceja-orange transition hover:brightness-110"
				>
					Acessar banco de talentos
					<span aria-hidden="true">→</span>
				</a>
			</article>
		</div>
	</section>

	<section class="bg-white py-20">
		<div class="mx-auto grid w-full max-w-7xl items-center gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
			<div class="rounded-[2rem] border border-ceja-blue-light bg-white p-8 shadow-sm sm:p-10">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Visão Estratégica</p>
				<h2 class="mt-3 text-3xl font-black text-ceja-blue-dark sm:text-4xl">Slogan Corporativo</h2>
				<blockquote class="mt-5 border-l-4 border-ceja-orange pl-5">
					<p class="text-xl font-bold text-ceja-blue-dark">
						"Formando talentos. Fortalecendo organizações. Transformando realidades."
					</p>
				</blockquote>
				<p class="mt-5 text-sm leading-relaxed text-ceja-muted">
					Acreditamos que a aprendizagem profissional vai muito além do cumprimento de uma obrigação legal. Ela representa uma oportunidade concreta de desenvolver talentos, fortalecer organizações e transformar realidades. Ao conectar jovens ao mundo do trabalho por meio de uma formação estruturada, promovemos inclusão, qualificação profissional e desenvolvimento sustentável, gerando benefícios para os participantes, para as empresas e para a sociedade.
				</p>
				<p class="mt-5 rounded-2xl bg-ceja-blue-light/60 px-4 py-3 text-sm font-semibold text-ceja-blue-dark">
					Conformidade integral com a Lei nº 10.097/2000 (Lei da Aprendizagem).
				</p>
			</div>
			<div class="overflow-hidden rounded-[2rem] border-8 border-white shadow-xl">
				<Image
					src={diferencialJovemAprendiz}
					alt="Jovem aprendiz sorrindo com crachá em ambiente profissional de formação"
					width={1400}
					height={933}
					format="webp"
					quality="mid"
					class="h-[360px] w-full object-cover"
				/>
			</div>
		</div>
	</section>

	<section id="contratar-aprendiz" class="bg-ceja-blue-dark py-16">
		<div class="mx-auto flex w-full max-w-7xl flex-col items-start justify-between gap-6 px-4 sm:px-6 lg:flex-row lg:items-center lg:px-8">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-orange">Pronto para começar?</p>
				<h2 class="mt-2 text-3xl font-black text-white sm:text-4xl">Implemente o Jovem Aprendiz com o CEJA Brasil</h2>
				<p class="mt-4 max-w-2xl text-ceja-blue-light">
					Fale com nossa equipe e receba diagnóstico gratuito para estruturar o programa na sua empresa.
				</p>
			</div>
			<a
				href="/contato"
				class="inline-flex rounded-full bg-ceja-orange px-8 py-4 text-sm font-extrabold uppercase tracking-wide text-white transition hover:brightness-105"
			>
				Solicitar consultoria
			</a>
		</div>
	</section>
</Layout>
