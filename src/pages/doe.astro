---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import DoacaoDiretaSection from '../components/DoacaoDiretaSection.astro';
import dados from '../data/nota-fiscal-paulista.json';
import equipamentosSociais from '../assets/sociais/equipamentos-sociais.jpg';
import formacaoComunitaria from '../assets/sociais/formacao-comunitaria.jpg';
---

<Layout
	title="Doe ao CEJA Brasil | Doação Direta e Nota Fiscal Paulista"
	description="Faça sua doação ao CEJA Brasil por PIX ou valores simbólicos. Doe também pela Nota Fiscal Paulista (CNPJ 15.409.309/0001-07) e apoie formação de jovens, inclusão de PCDs e projetos sociais em São Paulo."
	keywords={dados.seoKeywords}
>
	<section class="relative overflow-hidden bg-white py-20">
		<div class="pointer-events-none absolute -left-10 top-16 h-24 w-24 rounded-full bg-ceja-green/20"></div>
		<div class="pointer-events-none absolute right-8 top-20 h-20 w-20 rounded-[45%_55%_50%_50%] bg-ceja-blue/15"></div>

		<div class="mx-auto grid w-full max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-green-a11y">Contribua sem custo</p>
				<h1 class="mt-4 text-4xl font-black leading-tight text-ceja-blue-dark sm:text-5xl lg:text-6xl">
					{dados.hero.titulo}
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-relaxed text-ceja-muted">
					{dados.hero.subtitulo}
				</p>
				<div class="mt-6 inline-flex rounded-2xl border border-ceja-blue/20 bg-ceja-surface px-5 py-3 text-sm text-ceja-blue-dark">
					<span class="font-semibold">CNPJ CEJA Brasil:</span>
					<span class="ml-2 font-mono">{dados.cnpj}</span>
				</div>
				<div class="mt-9 flex flex-wrap items-center gap-4">
					<a
						href={dados.portalUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex rounded-full bg-ceja-green-a11y px-7 py-3 text-base font-semibold text-white transition hover:brightness-110"
						aria-label={`${dados.hero.ctaPortal} — abre em nova aba`}
					>
						{dados.hero.ctaPortal}
					</a>
					<a
						href="#faca-sua-doacao"
						class="inline-flex rounded-full border-2 border-ceja-blue px-7 py-3 text-base font-semibold text-ceja-blue transition hover:bg-ceja-blue hover:text-white"
					>
						Fazer doação direta
					</a>
				</div>
			</div>

			<div class="relative mx-auto w-full max-w-xl">
				<div class="pointer-events-none absolute -left-6 top-6 h-14 w-24 rounded-[60%_40%_45%_55%] bg-ceja-green/25"></div>
				<div class="pointer-events-none absolute right-3 -bottom-3 h-16 w-28 rounded-[35%_65%_50%_50%] bg-ceja-blue/20"></div>
				<div class="overflow-hidden rounded-[2.8rem] border-8 border-white bg-white shadow-[0_30px_60px_-28px_rgba(15,74,110,0.28)]">
					<Image
						src={equipamentosSociais}
						alt="Comunidade em atividade educacional promovida pelo CEJA Brasil com apoio de doações sociais"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						loading="eager"
						fetchpriority="high"
						class="h-[420px] w-full object-cover"
					/>
				</div>
				<div class="absolute -bottom-8 left-4 hidden h-36 w-44 overflow-hidden rounded-[1.6rem] border-4 border-white bg-white shadow-xl sm:block">
					<Image
						src={formacaoComunitaria}
						alt="Jovens em formação comunitária apoiada por projetos sociais do CEJA Brasil"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						class="h-full w-full object-cover"
					/>
				</div>
			</div>
		</div>
	</section>

	<DoacaoDiretaSection />

	<section class="bg-ceja-surface py-20 sm:py-24" aria-labelledby="sobre-nfp">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="overflow-hidden rounded-[2.5rem] border border-ceja-blue-light bg-white shadow-sm">
				<div class="grid gap-10 p-8 sm:p-10 lg:grid-cols-[1fr_1.1fr] lg:items-start lg:p-12">
					<div>
						<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue-a11y">Programa oficial</p>
						<h2 id="sobre-nfp" class="mt-3 text-3xl font-black leading-tight text-ceja-blue-dark sm:text-4xl">
							{dados.sobrePrograma.titulo}
						</h2>
						<p class="mt-4 text-lg font-semibold leading-snug text-ceja-blue">
							{dados.subtitulo}
						</p>
					</div>

					<div class="space-y-5 text-base leading-relaxed text-ceja-muted">
						{
							dados.sobrePrograma.paragrafos.map((paragrafo) => (
								<p>{paragrafo}</p>
							))
						}
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="passo-a-passo" class="bg-white py-20 sm:py-24" aria-labelledby="passos-titulo">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-2xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-green-a11y">Passo a passo</p>
				<h2 id="passos-titulo" class="mt-3 text-3xl font-bold text-ceja-blue-dark sm:text-4xl">
					Como Doar em 4 Passos
				</h2>
				<p class="mt-4 text-base leading-relaxed text-ceja-muted">
					{dados.intro}
				</p>
			</div>

			<ol class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
				{
					dados.passos.map((passo, index) => (
						<li class="rounded-[2rem] border border-ceja-blue-light bg-ceja-surface p-6">
							<span
								class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-ceja-header text-sm font-bold text-white"
								aria-hidden="true"
							>
								{index + 1}
							</span>
							<h3 class="mt-4 text-lg font-bold text-ceja-blue-dark">{passo.titulo}</h3>
							<p class="mt-2 text-sm leading-relaxed text-ceja-muted">{passo.descricao}</p>
						</li>
					))
				}
			</ol>

			<div class="mt-10 text-center">
				<a
					href={dados.portalUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex rounded-full bg-ceja-green-a11y px-8 py-4 text-sm font-extrabold uppercase tracking-wide text-white transition hover:brightness-110"
					aria-label={`${dados.portalLabel} — abre em nova aba`}
				>
					{dados.portalLabel}
				</a>
			</div>
		</div>
	</section>

	<section class="bg-ceja-surface py-20 sm:py-24" aria-labelledby="projetos-titulo">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-2xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue-a11y">Onde sua doação chega</p>
				<h2 id="projetos-titulo" class="mt-3 text-3xl font-bold text-ceja-blue-dark sm:text-4xl">
					Projetos Apoiados pela Sua Contribuição
				</h2>
				<p class="mt-4 text-base leading-relaxed text-ceja-muted">
					{dados.impacto}
				</p>
			</div>

			<div class="mt-12 grid gap-6 sm:grid-cols-2">
				{
					dados.projetosApoiados.map((projeto) => (
						<article class="rounded-[2rem] border border-ceja-blue-light bg-white p-8 shadow-sm">
							<h3 class="text-xl font-bold text-ceja-blue-dark">{projeto.titulo}</h3>
							<p class="mt-3 text-sm leading-relaxed text-ceja-muted">{projeto.descricao}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-white py-20 sm:py-24" aria-labelledby="faq-titulo">
		<div class="mx-auto w-full max-w-3xl px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue-a11y">Dúvidas frequentes</p>
				<h2 id="faq-titulo" class="mt-3 text-3xl font-bold text-ceja-blue-dark sm:text-4xl">
					Perguntas sobre a Doação
				</h2>
			</div>

			<div class="mt-10 space-y-4">
				{
					dados.faq.map((item) => (
						<details class="group rounded-2xl border border-ceja-blue-light bg-ceja-surface px-6 py-4">
							<summary class="cursor-pointer list-none font-semibold text-ceja-blue-dark marker:content-none [&::-webkit-details-marker]:hidden">
								<span class="flex items-center justify-between gap-4">
									{item.pergunta}
									<span class="text-ceja-green-a11y transition group-open:rotate-45" aria-hidden="true">+</span>
								</span>
							</summary>
							<p class="mt-3 text-sm leading-relaxed text-ceja-muted">{item.resposta}</p>
						</details>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-ceja-header py-16 sm:py-20" aria-labelledby="cta-final">
		<div class="mx-auto w-full max-w-4xl px-4 text-center sm:px-6 lg:px-8">
			<h2 id="cta-final" class="text-3xl font-black text-white sm:text-4xl">
				Sua Doação Transforma Vidas em São Paulo
			</h2>
			<p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-ceja-blue-light">
				Cadastre-se no portal, acumule créditos nas suas compras e escolha o CEJA Brasil como destinatário. É rápido, gratuito e com impacto social real.
			</p>
			<div class="mt-8 flex flex-wrap items-center justify-center gap-4">
				<a
					href={dados.portalUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex rounded-full bg-ceja-orange-a11y px-8 py-4 text-sm font-extrabold uppercase tracking-wide text-white transition hover:brightness-105"
					aria-label={`${dados.portalLabel} — abre em nova aba`}
				>
					{dados.portalLabel}
				</a>
				<a
					href="/contato"
					class="inline-flex rounded-full border-2 border-white px-8 py-4 text-sm font-extrabold uppercase tracking-wide text-white transition hover:bg-white hover:text-ceja-header"
				>
					Falar com o CEJA
				</a>
			</div>
		</div>
	</section>
</Layout>
