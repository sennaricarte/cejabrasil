---
import Layout from '../layouts/Layout.astro';
import Editor from '../components/dashboard/ArticleEditorDashboard';
---

<Layout
	title="Dashboard de Artigos CEJA Brasil | Editor Tiptap"
	description="Painel administrativo CEJA Brasil para criação e publicação de artigos com editor Tiptap, categorias e recursos de formatação avançada."
	keywords="dashboard artigos, tiptap, editor de conteúdo, ceja brasil, publicação de artigos"
>
	<section class="bg-gray-50 py-10">
		<div class="mx-auto w-full max-w-[1400px] px-4 sm:px-6 lg:px-8">
			<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Dashboard Editorial</p>
				<h1 class="mt-2 text-3xl font-extrabold text-[#0a1d37] sm:text-4xl">Gerenciador de Artigos</h1>
				<p class="mt-3 max-w-3xl text-slate-600">
					Painel administrativo para criar, revisar e publicar conteúdos do CEJA Brasil com fluxo editorial claro e profissional.
				</p>
			</div>
		</div>
		<Editor client:load />
	</section>
</Layout>
