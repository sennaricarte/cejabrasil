---
import { Image } from 'astro:assets';
import certificacoesData from '../data/certificacoes.json';
import seloCmdca from '../assets/selos/cmdca.png';
import seloComas from '../assets/selos/comas.png';
import seloCebas from '../assets/selos/cebas.png';

const seloMap = {
	cmdca: seloCmdca,
	comas: seloComas,
	cebas: seloCebas,
} as const;

const accentClasses = [
	'border-ceja-blue/30 bg-ceja-blue/10 text-ceja-blue-a11y',
	'border-ceja-green/30 bg-ceja-green-light text-ceja-green-a11y',
	'border-ceja-orange/30 bg-ceja-orange/10 text-ceja-orange-a11y',
	'border-ceja-blue-dark/20 bg-ceja-blue-light text-ceja-blue-dark',
];
---

<section id="certificacoes" class="bg-ceja-surface py-20 sm:py-24" aria-labelledby="certificacoes-titulo">
	<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mx-auto max-w-3xl text-center">
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue-a11y">
				{certificacoesData.titulo}
			</p>
			<h2 id="certificacoes-titulo" class="mt-3 text-3xl font-bold text-ceja-blue-dark sm:text-4xl">
				{certificacoesData.subtitulo}
			</h2>
			<p class="mt-5 text-base leading-relaxed text-ceja-muted">
				{certificacoesData.intro}
			</p>
		</div>

		<div
			class="mx-auto mt-12 max-w-4xl rounded-[2rem] border border-ceja-blue-light bg-white p-6 shadow-sm sm:p-8"
			aria-label="Selos institucionais do CEJA Brasil"
		>
			<p class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-ceja-muted">
				Certificações oficiais
			</p>
			<ul class="mt-6 grid grid-cols-1 items-center gap-8 sm:grid-cols-3 sm:gap-6">
				{
					certificacoesData.selos.map((selo) => (
						<li class="flex flex-col items-center text-center">
							<div class="flex h-28 w-full items-center justify-center rounded-2xl bg-ceja-surface/80 px-4 py-3">
								<Image
									src={seloMap[selo.imageKey as keyof typeof seloMap]}
									alt={selo.alt}
									width={320}
									height={200}
									format="webp"
									quality="mid"
									class="max-h-24 w-auto object-contain"
								/>
							</div>
							<p class="mt-3 text-sm font-bold text-ceja-blue-dark">{selo.sigla}</p>
						</li>
					))
				}
			</ul>
		</div>

		<div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
			{
				certificacoesData.certificacoes.map((item, index) => (
					<article class="flex h-full flex-col rounded-[2rem] border border-ceja-blue-light bg-white p-7 shadow-sm transition hover:shadow-md">
						<div
							class:list={[
								'inline-flex w-fit rounded-full border px-4 py-1.5 text-xs font-extrabold uppercase tracking-wide',
								accentClasses[index % accentClasses.length],
							]}
						>
							{item.sigla}
						</div>
						<h3 class="mt-5 text-xl font-bold leading-snug text-ceja-blue-dark">{item.nome}</h3>
						<p class="mt-1 text-sm font-semibold text-ceja-blue">{item.destaque}</p>
						<p class="mt-4 flex-1 text-sm leading-relaxed text-ceja-muted">{item.descricao}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
