---
import { Image } from 'astro:assets';
import '../styles/global.css';
import cejaLogo from '../assets/ceja-brasil-logo.png';
import lexend600 from '@fontsource/lexend/files/lexend-latin-600-normal.woff2?url';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	image?: string;
	ogType?: string;
}

const {
	title = 'CEJA Brasil',
	description = 'CEJA Brasil: formação e inclusão de jovens e PCDs no mercado de trabalho.',
	keywords = 'jovem aprendiz, estágio, inclusão pcd, cursos profissionalizantes, ceja brasil',
	image = '/og-image.png',
	ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preload" href={lexend600} as="font" type="font/woff2" crossorigin />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<link rel="canonical" href={canonicalURL} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="pt_BR" />
		<meta property="og:site_name" content="CEJA Brasil" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				'@context': 'https://schema.org',
				'@type': 'NGO',
				name: 'CEJA Brasil',
				url: 'https://cejabrasil.org.br',
				logo: 'https://cejabrasil.org.br/og-image.png',
				description:
					'ONG especializada na formação e inclusão de jovens e PCDs no mercado de trabalho.',
				email: 'atendimento@cejabrasil.org.br',
				telephone: '+55 11 3214-4923',
				address: {
					'@type': 'PostalAddress',
					streetAddress: 'Rua Conselheiro Crispiniano, 105 - 3º Andar - Sala 32',
					addressLocality: 'São Paulo',
					addressRegion: 'SP',
					addressCountry: 'BR',
				},
				contactPoint: [
					{
						'@type': 'ContactPoint',
						telephone: '+55 11 3214-4923',
						contactType: 'customer service',
						areaServed: 'BR',
						availableLanguage: 'Portuguese',
					},
					{
						'@type': 'ContactPoint',
						telephone: '+55 11 96693-1935',
						contactType: 'customer support',
						contactOption: 'WhatsApp',
						areaServed: 'BR',
						availableLanguage: 'Portuguese',
					},
					{
						'@type': 'ContactPoint',
						telephone: '+55 11 95495-4941',
						contactType: 'customer support',
						contactOption: 'WhatsApp',
						areaServed: 'BR',
						availableLanguage: 'Portuguese',
					},
					{
						'@type': 'ContactPoint',
						telephone: '+55 11 94595-7746',
						contactType: 'administrative',
						contactOption: 'WhatsApp',
						areaServed: 'BR',
						availableLanguage: 'Portuguese',
					},
				],
				sameAs: [
					'https://www.instagram.com/cejabrasilsp/',
					'https://www.facebook.com/cejabrasil/',
				],
			})}
		/>
	</head>
	<body class="bg-ceja-surface font-sans text-ceja-blue-dark antialiased">
		<header class="fixed inset-x-0 top-0 z-50 shadow-sm">
			<div class="border-b border-ceja-blue-light bg-ceja-blue-light/60">
				<div
					class="mx-auto flex h-9 w-full max-w-7xl items-center justify-between px-4 text-xs text-ceja-muted sm:px-6 lg:px-8"
				>
					<div class="flex items-center gap-3" aria-label="Redes sociais CEJA Brasil">
						<a
							href="https://www.facebook.com/cejabrasil/"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Facebook CEJA Brasil"
							class="transition-colors hover:text-ceja-blue"
						>
							<svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
								<path d="M13.5 9H16V6h-2.5A4.5 4.5 0 0 0 9 10.5V13H6v3h3v6h3v-6h3l1-3h-4v-2.5A1.5 1.5 0 0 1 13.5 9Z" />
							</svg>
						</a>
						<a
							href="https://www.instagram.com/cejabrasilsp/"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Instagram CEJA Brasil"
							class="transition-colors hover:text-ceja-blue"
						>
							<svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
								<path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5a4.25 4.25 0 0 0 4.25 4.25h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5a4.25 4.25 0 0 0-4.25-4.25h-8.5Zm8.75 1.75a1 1 0 1 1 0 2 1 1 0 0 1 0-2ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Z" />
							</svg>
						</a>
					</div>
					<div class="flex items-center gap-5">
						<p aria-label="Telefone de contato">Telefone: (11) 3214-4923</p>
						<p class="hidden md:block" aria-label="Endereço do CEJA Brasil">
							Rua Conselheiro Crispiniano, 105 - Centro, São Paulo, SP
						</p>
					</div>
				</div>
			</div>

			<div class="border-b border-ceja-blue-dark/15 bg-ceja-header">
				<div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-4 sm:px-6 sm:py-6 lg:px-8">
					<a href="/" aria-label="Página inicial CEJA Brasil">
						<Image
							src={cejaLogo}
							alt="Logo CEJA Brasil com globo azul e mapa do Brasil em amarelo"
							width={1024}
							height={369}
							class="h-auto w-44 object-contain sm:w-60"
						/>
					</a>

					<button
						type="button"
						id="menu-toggle"
						class="inline-flex h-11 w-11 items-center justify-center rounded-xl text-white transition hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-ceja-yellow lg:hidden"
						aria-controls="menu-mobile"
						aria-expanded="false"
						aria-label="Abrir menu de navegação"
					>
						<svg id="menu-icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6" aria-hidden="true">
							<path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
						</svg>
						<svg id="menu-icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden h-6 w-6" aria-hidden="true">
							<path stroke-linecap="round" d="M6 6l12 12M18 6L6 18" />
						</svg>
					</button>

					<nav class="hidden lg:block" aria-label="Navegação principal">
						<ul class="flex items-center gap-4 text-base font-medium text-white sm:gap-6">
							<li><a class="relative inline-flex py-1 transition-colors duration-300 hover:text-ceja-yellow after:absolute after:left-1/2 after:top-full after:mt-1 after:h-1.5 after:w-1.5 after:-translate-x-1/2 after:rounded-full after:bg-ceja-yellow after:opacity-0 after:transition-opacity after:duration-300 hover:after:opacity-100" href="/">Home</a></li>
							<li><a class="relative inline-flex py-1 transition-colors duration-300 hover:text-ceja-yellow after:absolute after:left-1/2 after:top-full after:mt-1 after:h-1.5 after:w-1.5 after:-translate-x-1/2 after:rounded-full after:bg-ceja-yellow after:opacity-0 after:transition-opacity after:duration-300 hover:after:opacity-100" href="/sobre">Sobre</a></li>
							<li><a class="relative inline-flex py-1 transition-colors duration-300 hover:text-ceja-yellow after:absolute after:left-1/2 after:top-full after:mt-1 after:h-1.5 after:w-1.5 after:-translate-x-1/2 after:rounded-full after:bg-ceja-yellow after:opacity-0 after:transition-opacity after:duration-300 hover:after:opacity-100" href="/jovem-aprendiz">Jovem Aprendiz</a></li>
							<li class="group relative">
								<a
									class="relative inline-flex items-center gap-1 py-1 transition-colors duration-300 hover:text-ceja-yellow after:absolute after:left-1/2 after:top-full after:mt-1 after:h-1.5 after:w-1.5 after:-translate-x-1/2 after:rounded-full after:bg-ceja-yellow after:opacity-0 after:transition-opacity after:duration-300 group-hover:after:opacity-100 group-focus-within:after:opacity-100"
									href="/vagas"
									aria-haspopup="true"
								>
									Vagas
									<svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
										<path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 10.94l3.71-3.71a.75.75 0 1 1 1.06 1.06l-4.24 4.25a.75.75 0 0 1-1.06 0L5.21 8.29a.75.75 0 0 1 .02-1.08Z" clip-rule="evenodd" />
									</svg>
								</a>
								<ul
									class="invisible absolute left-0 top-full z-50 mt-3 min-w-48 rounded-2xl border border-ceja-blue-dark/20 bg-ceja-header py-2 opacity-0 shadow-lg transition-all duration-200 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
									aria-label="Submenu de vagas"
								>
									<li>
										<a href="/vagas" class="block px-4 py-2.5 text-sm text-white transition hover:bg-white/10 hover:text-ceja-yellow">
											Banco de Talentos
										</a>
									</li>
									<li>
										<a href="/vagas/estagio" class="block px-4 py-2.5 text-sm text-white transition hover:bg-white/10 hover:text-ceja-yellow">
											Estágio
										</a>
									</li>
									<li>
										<a href="/vagas/pcd" class="block px-4 py-2.5 text-sm text-white transition hover:bg-white/10 hover:text-ceja-yellow">
											PCD
										</a>
									</li>
								</ul>
							</li>
							<li><a class="relative inline-flex py-1 transition-colors duration-300 hover:text-ceja-yellow after:absolute after:left-1/2 after:top-full after:mt-1 after:h-1.5 after:w-1.5 after:-translate-x-1/2 after:rounded-full after:bg-ceja-yellow after:opacity-0 after:transition-opacity after:duration-300 hover:after:opacity-100" href="/cursos">Cursos</a></li>
							<li><a class="relative inline-flex py-1 transition-colors duration-300 hover:text-ceja-yellow after:absolute after:left-1/2 after:top-full after:mt-1 after:h-1.5 after:w-1.5 after:-translate-x-1/2 after:rounded-full after:bg-ceja-yellow after:opacity-0 after:transition-opacity after:duration-300 hover:after:opacity-100" href="/empresas">Empresas</a></li>
							<li><a class="relative inline-flex py-1 transition-colors duration-300 hover:text-ceja-yellow after:absolute after:left-1/2 after:top-full after:mt-1 after:h-1.5 after:w-1.5 after:-translate-x-1/2 after:rounded-full after:bg-ceja-yellow after:opacity-0 after:transition-opacity after:duration-300 hover:after:opacity-100" href="/doe">Doe</a></li>
							<li><a class="relative inline-flex py-1 transition-colors duration-300 hover:text-ceja-yellow after:absolute after:left-1/2 after:top-full after:mt-1 after:h-1.5 after:w-1.5 after:-translate-x-1/2 after:rounded-full after:bg-ceja-yellow after:opacity-0 after:transition-opacity after:duration-300 hover:after:opacity-100" href="/contato">Contato</a></li>
						</ul>
					</nav>
				</div>

				<nav
					id="menu-mobile"
					class="hidden border-t border-white/10 bg-ceja-header lg:hidden"
					aria-label="Navegação mobile"
					hidden
				>
					<ul class="mx-auto flex w-full max-w-7xl flex-col px-4 py-3 text-base font-medium text-white sm:px-6">
						<li>
							<a href="/" class="menu-mobile-link block rounded-xl px-3 py-3 transition hover:bg-white/10 hover:text-ceja-yellow">Home</a>
						</li>
						<li>
							<a href="/sobre" class="menu-mobile-link block rounded-xl px-3 py-3 transition hover:bg-white/10 hover:text-ceja-yellow">Sobre</a>
						</li>
						<li>
							<a href="/jovem-aprendiz" class="menu-mobile-link block rounded-xl px-3 py-3 transition hover:bg-white/10 hover:text-ceja-yellow">Jovem Aprendiz</a>
						</li>
						<li>
							<button
								type="button"
								id="menu-vagas-toggle"
								class="flex w-full items-center justify-between rounded-xl px-3 py-3 text-left transition hover:bg-white/10 hover:text-ceja-yellow"
								aria-expanded="false"
								aria-controls="menu-vagas-submenu"
							>
								<span>Vagas</span>
								<svg id="menu-vagas-chevron" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 transition-transform" aria-hidden="true">
									<path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 10.94l3.71-3.71a.75.75 0 1 1 1.06 1.06l-4.24 4.25a.75.75 0 0 1-1.06 0L5.21 8.29a.75.75 0 0 1 .02-1.08Z" clip-rule="evenodd" />
								</svg>
							</button>
							<ul id="menu-vagas-submenu" class="mb-1 ml-3 hidden border-l border-white/20 pl-3" hidden>
								<li>
									<a href="/vagas" class="menu-mobile-link block rounded-xl px-3 py-2.5 text-sm transition hover:bg-white/10 hover:text-ceja-yellow">Banco de Talentos</a>
								</li>
								<li>
									<a href="/vagas/estagio" class="menu-mobile-link block rounded-xl px-3 py-2.5 text-sm transition hover:bg-white/10 hover:text-ceja-yellow">Estágio</a>
								</li>
								<li>
									<a href="/vagas/pcd" class="menu-mobile-link block rounded-xl px-3 py-2.5 text-sm transition hover:bg-white/10 hover:text-ceja-yellow">PCD</a>
								</li>
							</ul>
						</li>
						<li>
							<a href="/cursos" class="menu-mobile-link block rounded-xl px-3 py-3 transition hover:bg-white/10 hover:text-ceja-yellow">Cursos</a>
						</li>
						<li>
							<a href="/empresas" class="menu-mobile-link block rounded-xl px-3 py-3 transition hover:bg-white/10 hover:text-ceja-yellow">Empresas</a>
						</li>
						<li>
							<a href="/doe" class="menu-mobile-link block rounded-xl px-3 py-3 transition hover:bg-white/10 hover:text-ceja-yellow">Doe</a>
						</li>
						<li>
							<a href="/contato" class="menu-mobile-link block rounded-xl px-3 py-3 transition hover:bg-white/10 hover:text-ceja-yellow">Contato</a>
						</li>
					</ul>
				</nav>
			</div>
		</header>

		<main class="pt-28 sm:pt-32 lg:pt-36">
			<slot />
		</main>

		<script>
			const menuToggle = document.getElementById('menu-toggle');
			const menuMobile = document.getElementById('menu-mobile');
			const iconOpen = document.getElementById('menu-icon-open');
			const iconClose = document.getElementById('menu-icon-close');
			const vagasToggle = document.getElementById('menu-vagas-toggle');
			const vagasSubmenu = document.getElementById('menu-vagas-submenu');
			const vagasChevron = document.getElementById('menu-vagas-chevron');

			const setMenuOpen = (open) => {
				if (!menuToggle || !menuMobile || !iconOpen || !iconClose) return;
				menuToggle.setAttribute('aria-expanded', String(open));
				menuToggle.setAttribute('aria-label', open ? 'Fechar menu de navegação' : 'Abrir menu de navegação');
				menuMobile.hidden = !open;
				menuMobile.classList.toggle('hidden', !open);
				iconOpen.classList.toggle('hidden', open);
				iconClose.classList.toggle('hidden', !open);
				document.body.classList.toggle('overflow-hidden', open);
			};

			const setVagasOpen = (open) => {
				if (!vagasToggle || !vagasSubmenu || !vagasChevron) return;
				vagasToggle.setAttribute('aria-expanded', String(open));
				vagasSubmenu.hidden = !open;
				vagasSubmenu.classList.toggle('hidden', !open);
				vagasChevron.classList.toggle('rotate-180', open);
			};

			menuToggle?.addEventListener('click', () => {
				const open = menuToggle.getAttribute('aria-expanded') !== 'true';
				setMenuOpen(open);
				if (!open) setVagasOpen(false);
			});

			vagasToggle?.addEventListener('click', () => {
				const open = vagasToggle.getAttribute('aria-expanded') !== 'true';
				setVagasOpen(open);
			});

			menuMobile?.querySelectorAll('.menu-mobile-link').forEach((link) => {
				link.addEventListener('click', () => {
					setMenuOpen(false);
					setVagasOpen(false);
				});
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					setMenuOpen(false);
					setVagasOpen(false);
					menuToggle?.focus();
				}
			});

			window.addEventListener('resize', () => {
				if (window.matchMedia('(min-width: 1024px)').matches) {
					setMenuOpen(false);
					setVagasOpen(false);
				}
			});
		</script>

		<section
			class="relative overflow-hidden bg-ceja-header py-14 sm:py-16"
			aria-labelledby="cta-inclusao-titulo"
		>
			<div class="pointer-events-none absolute -left-16 top-0 h-40 w-40 rounded-full bg-ceja-orange/20"></div>
			<div class="pointer-events-none absolute -right-10 bottom-0 h-32 w-32 rounded-full bg-ceja-green/20"></div>

			<div class="relative mx-auto flex w-full max-w-7xl flex-col items-center gap-6 px-4 text-center sm:px-6 lg:flex-row lg:justify-between lg:text-left lg:px-8">
				<div class="max-w-2xl">
					<p class="text-sm font-semibold uppercase tracking-[0.2em] text-white">Inclusão produtiva</p>
					<h2 id="cta-inclusao-titulo" class="mt-2 text-2xl font-black text-white sm:text-3xl">
						Inclusão para o Mundo do Trabalho
					</h2>
					<p class="mt-3 text-sm leading-relaxed text-ceja-blue-light sm:text-base">
						Consultoria, recrutamento e acompanhamento especializado para empresas e profissionais PCD.
					</p>
				</div>
				<a
					href="/vagas/pcd"
					class="inline-flex shrink-0 items-center rounded-full bg-ceja-orange-a11y px-8 py-4 text-sm font-extrabold uppercase tracking-wide text-white shadow-lg transition hover:-translate-y-0.5 hover:brightness-105"
					aria-label="Conhecer o programa de inclusão PCD do CEJA Brasil"
				>
					Conhecer o programa PCD
				</a>
			</div>
		</section>

		<a
			href="/vagas/pcd#contato-pcd"
			aria-label="Abrir recursos de acessibilidade e contato especializado em inclusão PCD"
			class="fixed bottom-5 left-5 z-[60] inline-flex items-center gap-2 rounded-full border-2 border-ceja-green bg-ceja-blue-dark px-4 py-3 text-sm font-bold text-white shadow-lg transition hover:border-ceja-green hover:bg-ceja-green-a11y focus:outline-none focus-visible:ring-2 focus-visible:ring-ceja-blue-light focus-visible:ring-offset-2 focus-visible:ring-offset-ceja-blue-dark"
		>
			<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
				<path d="M12 2.25a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5ZM8.25 9A2.25 2.25 0 0 0 6 11.25v2.5a.75.75 0 0 0 1.5 0v-2.5a.75.75 0 0 1 .75-.75h.257a3.74 3.74 0 0 1 2.552 1.005l.41.384a.75.75 0 0 0 1.026 0l.41-.384a3.74 3.74 0 0 1 2.552-1.005h.257a.75.75 0 0 1 .75.75v2.5a.75.75 0 0 0 1.5 0v-2.5A2.25 2.25 0 0 0 15.75 9h-1.69a5.22 5.22 0 0 0-2.06.425A5.22 5.22 0 0 0 9.94 9H8.25ZM12 14.25a.75.75 0 0 1 .75.75v6a.75.75 0 0 1-1.5 0v-6a.75.75 0 0 1 .75-.75Z" />
			</svg>
			<span>Acessibilidade</span>
		</a>

		<footer class="relative mt-20 overflow-hidden bg-ceja-blue-dark text-white">
			<div class="pointer-events-none absolute inset-x-0 -top-16 h-24 rounded-b-[50%] bg-white sm:-top-20 sm:h-28"></div>

			<div class="relative mx-auto w-full max-w-7xl px-4 pb-0 pt-20 sm:px-6 lg:px-8">
				<div class="grid gap-10 pb-10 md:grid-cols-2 xl:grid-cols-4">
					<div>
						<a href="/" aria-label="Página inicial CEJA Brasil" class="text-2xl font-extrabold tracking-tight text-white">
							CEJA <span class="text-ceja-yellow">BRASIL</span>
						</a>
						<p class="mt-4 max-w-sm text-sm leading-relaxed text-ceja-blue-light">
							ONG especializada na formação e inclusão de jovens e PCDs no mercado de trabalho. Transformando vidas através da educação e oportunidade.
						</p>
						<div class="mt-6 flex items-center gap-3" aria-label="Redes sociais CEJA Brasil">
							<a
								href="https://www.instagram.com/cejabrasilsp/"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Instagram CEJA Brasil"
