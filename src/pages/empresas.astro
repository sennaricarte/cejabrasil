---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import empresasData from '../data/empresas.json';
import heroEstagio from '../assets/estagio/hero-estagio.jpg';
import corporativoEstagio from '../assets/estagio/corporativo-estagio.jpg';
import heroPcd from '../assets/pcd/hero-pcd.jpg';
---

<Layout
	title="Para Empresas CEJA Brasil | Soluções em Aprendizagem, Estágio e Inclusão PCD"
	description="Página para empresas do CEJA Brasil com soluções completas em Jovem Aprendiz, Estágio e Inclusão PCD, segurança jurídica e gestão administrativa."
	keywords="para empresas, jovem aprendiz empresas, estágio corporativo, inclusão pcd empresas, segurança jurídica trabalhista"
>
	<section class="relative overflow-hidden bg-white py-20">
		<div class="pointer-events-none absolute -left-8 top-14 h-24 w-24 rounded-full bg-ceja-blue/15"></div>
		<div class="pointer-events-none absolute right-8 top-24 h-20 w-20 rounded-[45%_55%_60%_40%] bg-[#FDCB08]/35"></div>
		<div class="mx-auto grid w-full max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Para Empresas</p>
				<h1 class="mt-4 text-4xl font-black leading-tight text-[#0a1d37] sm:text-5xl lg:text-6xl">
					{empresasData.hero.title}
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-relaxed text-gray-600">
					{empresasData.hero.subtitle}
				</p>
				<a
					href="#consultoria-corporativa"
					class="mt-9 inline-flex rounded-full bg-ceja-yellow px-8 py-3 text-sm font-extrabold uppercase tracking-wide text-black transition hover:brightness-95"
				>
					Solicitar Consultoria
				</a>
			</div>

			<div class="relative mx-auto w-full max-w-2xl">
				<div class="pointer-events-none absolute -left-7 top-4 h-16 w-24 rounded-[60%_40%_45%_55%] bg-ceja-blue/15"></div>
				<div class="pointer-events-none absolute right-2 bottom-10 h-14 w-28 rounded-[35%_65%_50%_50%] bg-[#FDCB08]/45"></div>

				<div class="overflow-hidden rounded-[2.8rem] border-8 border-white bg-white shadow-[0_30px_60px_-28px_rgba(10,29,55,0.45)]">
					<Image
						src={heroEstagio}
						alt="Equipe corporativa diversa colaborando em escritório moderno"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						class="h-[440px] w-full object-cover"
					/>
				</div>

				<div class="absolute -bottom-9 left-4 hidden h-40 w-52 overflow-hidden rounded-[1.6rem] border-4 border-white bg-white shadow-xl sm:block">
					<Image
						src={corporativoEstagio}
						alt="Profissionais em reunião de alinhamento com consultoria CEJA"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						class="h-full w-full object-cover"
					/>
				</div>

				<div class="absolute -right-5 top-12 hidden h-28 w-40 overflow-hidden rounded-[1.4rem] border-4 border-white bg-white shadow-lg lg:block">
					<Image
						src={heroPcd}
						alt="Profissional PCD integrado ao time em ambiente corporativo"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						class="h-full w-full object-cover"
					/>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-20">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Por que o CEJA?</p>
				<h2 class="mt-3 text-3xl font-bold text-[#0a1d37] sm:text-4xl">Benefícios para sua operação e para sua marca</h2>
			</div>

			<div class="mt-10 grid gap-6 md:grid-cols-2">
				{
					empresasData.beneficios.map((beneficio, index) => (
						<article class="rounded-[2rem] border border-gray-100 bg-white p-7 shadow-sm">
							<div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue">
								{index === 0 && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
										<path d="M4 7h16M4 12h10M4 17h7" />
										<path d="M16 14.5 19.5 18 22 15.5" />
									</svg>
								)}
								{index === 1 && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
										<path d="M12 3 5 6v6c0 4.2 2.7 7.3 7 9 4.3-1.7 7-4.8 7-9V6l-7-3Z" />
										<path d="m9.5 12 1.8 1.8L15 10.2" />
									</svg>
								)}
								{index === 2 && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
										<path d="M12 21a8 8 0 1 0-8-8h3l-4 5-4-5h3a13 13 0 1 1 13 13Z" />
										<path d="M12 8v4l3 2" />
									</svg>
								)}
								{index === 3 && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
										<circle cx="11" cy="11" r="6.5" />
										<path d="m16 16 4 4" />
										<path d="M8.5 11h5M11 8.5v5" />
									</svg>
								)}
							</div>
							<h3 class="mt-5 text-2xl font-bold text-[#0a1d37]">{beneficio.titulo}</h3>
							<p class="mt-3 text-sm leading-relaxed text-gray-600">{beneficio.descricao}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-white py-20">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Fluxo de Atendimento</p>
				<h2 class="mt-3 text-3xl font-bold text-[#0a1d37] sm:text-4xl">Um processo simples, técnico e previsível</h2>
			</div>

			<div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
				{
					empresasData.fluxoAtendimento.map((etapa, index) => (
						<div class="relative rounded-3xl border border-gray-100 bg-white p-6 shadow-sm">
							<span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#0a1d37] text-sm font-bold text-white">
								{index + 1}
							</span>
							<p class="mt-4 text-lg font-bold text-[#0a1d37]">{etapa}</p>
							{index < empresasData.fluxoAtendimento.length - 1 && (
								<div class="pointer-events-none absolute -right-3 top-1/2 hidden h-3 w-6 -translate-y-1/2 rounded-full bg-[#FDCB08]/80 xl:block"></div>
							)}
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-20">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="rounded-[2rem] border border-ceja-blue/20 bg-white p-8 shadow-sm sm:p-10">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Diferencial Técnico</p>
				<h2 class="mt-3 text-3xl font-black text-[#0a1d37] sm:text-4xl">CEJA Brasil é Entidade Qualificadora</h2>
				<p class="mt-5 max-w-4xl text-base leading-relaxed text-gray-600">
					Esse reconhecimento técnico reforça nossa autoridade para estruturar programas de aprendizagem com cumprimento legal, trilhas formativas e acompanhamento contínuo, reduzindo riscos trabalhistas e fortalecendo a governança da sua empresa.
				</p>
			</div>
		</div>
	</section>

	<section id="consultoria-corporativa" class="bg-[#0a1d37] py-16">
		<div class="mx-auto flex w-full max-w-7xl flex-col items-start justify-between gap-6 px-4 sm:px-6 lg:flex-row lg:items-center lg:px-8">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#FDCB08]">CTA Corporativo</p>
				<h2 class="mt-2 text-3xl font-black text-white sm:text-4xl">Pronto para transformar sua equipe?</h2>
			</div>
			<a
				href="#"
				class="inline-flex rounded-full bg-[#FDCB08] px-8 py-4 text-sm font-extrabold uppercase tracking-wide text-black transition hover:brightness-95"
			>
				SOLICITAR CONSULTORIA CORPORATIVA
			</a>
		</div>
	</section>
</Layout>
