---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import telematicaHero from '../../assets/courses/telematica-hero.png';
import dados from '../../data/cursos/telematica.json';
---

<Layout
	title="Curso de Telemática CEJA Brasil | Experiência do Cliente (CX)"
	description="Conheça o Programa de Formação em Experiência do Cliente (CX) do CEJA Brasil — Operação de Contact Center."
	keywords={dados.seoKeywords}
>
	<section class="relative overflow-hidden bg-white py-20">
		<div class="pointer-events-none absolute -left-10 top-16 h-24 w-24 rounded-full bg-ceja-blue/15"></div>
		<div class="pointer-events-none absolute right-8 top-20 h-20 w-20 rounded-[45%_55%_50%_50%] bg-ceja-green/20"></div>

		<div class="mx-auto grid w-full max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Arco Ocupacional</p>
				<h1 class="mt-4 text-4xl font-black leading-tight text-ceja-blue-dark sm:text-5xl lg:text-6xl">
					{dados.nomeComercial}
				</h1>
				<p class="mt-4 text-lg font-semibold text-ceja-blue">{dados.nomeOficial}</p>
				<p class="mt-6 max-w-2xl text-lg leading-relaxed text-ceja-muted">
					{dados.intro}
				</p>
				<div class="mt-6 inline-flex rounded-full bg-ceja-blue-light px-5 py-2 text-sm font-bold uppercase tracking-wide text-ceja-blue-dark">
					Carga horária: {dados.hours}
				</div>
			</div>

			<div class="relative mx-auto w-full max-w-xl">
				<div class="pointer-events-none absolute -left-6 top-6 h-14 w-24 rounded-[60%_40%_45%_55%] bg-ceja-blue/20"></div>
				<div class="pointer-events-none absolute right-3 -bottom-3 h-16 w-28 rounded-[35%_65%_50%_50%] bg-ceja-green/25"></div>
				<div class="overflow-hidden rounded-[2.8rem] border-8 border-white bg-white shadow-[0_30px_60px_-28px_rgba(15,74,110,0.28)]">
					<Image
						src={telematicaHero}
						alt="Profissional de atendimento sorrindo e cumprimentando cliente em ambiente de serviços"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						loading="eager"
						fetchpriority="high"
						class="h-[420px] w-full object-cover"
					/>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-ceja-surface py-20 sm:py-24" aria-labelledby="perfil-telematica">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="overflow-hidden rounded-[2.5rem] border border-ceja-blue-light bg-white shadow-sm">
				<div class="p-8 sm:p-10 lg:p-12">
					<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Competências desenvolvidas</p>
					<h2 id="perfil-telematica" class="mt-3 text-3xl font-black text-ceja-blue-dark sm:text-4xl">Perfil do Curso</h2>
					<p class="mt-4 max-w-3xl text-base leading-relaxed text-ceja-muted">
						O programa desenvolve competências para atuar em operações de contact center, dominando canais de comunicação e práticas de relacionamento que elevam a experiência do cliente.
					</p>

					<ul class="mt-10 grid gap-4 sm:grid-cols-2">
						{
							dados.perfil.map((item) => (
								<li class="flex gap-3 rounded-2xl border border-ceja-blue-light bg-ceja-surface px-5 py-4">
									<span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-ceja-blue text-xs font-bold text-white" aria-hidden="true">
										✓
									</span>
									<span class="text-sm leading-relaxed text-ceja-blue-dark">{item}</span>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-white py-16 sm:py-20">
		<div class="mx-auto flex w-full max-w-7xl flex-col items-start justify-between gap-6 px-4 sm:px-6 lg:flex-row lg:items-center lg:px-8">
			<p class="max-w-2xl text-lg font-semibold leading-relaxed text-ceja-blue-dark">
				Interessado em ser Jovem Aprendiz na área de telemática e atendimento ao cliente? Cadastre-se no banco de talentos do CEJA Brasil.
			</p>
			<div class="flex flex-wrap gap-4">
				<a
					href="/vagas"
					class="inline-flex rounded-full bg-ceja-orange px-8 py-4 text-sm font-extrabold uppercase tracking-wide text-white transition hover:brightness-105"
				>
					Cadastrar currículo
				</a>
				<a
					href="/cursos"
					class="inline-flex rounded-full border-2 border-ceja-blue px-8 py-4 text-sm font-extrabold uppercase tracking-wide text-ceja-blue transition hover:bg-ceja-blue hover:text-white"
				>
					Ver todos os cursos
				</a>
			</div>
		</div>
	</section>
</Layout>
