---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import empresasData from '../data/empresas.json';
import heroEstagio from '../assets/estagio/hero-estagio.jpg';
import corporativoEstagio from '../assets/estagio/corporativo-estagio.jpg';
import heroPcd from '../assets/pcd/hero-pcd.jpg';
---

<Layout
	title="Para Empresas CEJA Brasil | Soluções em Aprendizagem, Estágio e Inclusão PCD"
	description="Página para empresas do CEJA Brasil com soluções completas em Jovem Aprendiz, Estágio e Inclusão PCD, segurança jurídica e gestão administrativa."
	keywords="para empresas, jovem aprendiz empresas, estágio corporativo, inclusão pcd empresas, segurança jurídica trabalhista"
>
	<section class="relative overflow-hidden bg-white py-20">
		<div class="pointer-events-none absolute -left-8 top-14 h-24 w-24 rounded-full bg-ceja-blue/15"></div>
		<div class="pointer-events-none absolute right-8 top-24 h-20 w-20 rounded-[45%_55%_60%_40%] bg-ceja-orange/35"></div>
		<div class="mx-auto grid w-full max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Para Empresas</p>
				<h1 class="mt-4 text-4xl font-black leading-tight text-ceja-blue-dark sm:text-5xl lg:text-6xl">
					{empresasData.hero.title}
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-relaxed text-ceja-muted">
					{empresasData.hero.subtitle}
				</p>
				<a
					href="#consultoria-corporativa"
					class="mt-9 inline-flex rounded-full bg-ceja-orange px-8 py-3 text-sm font-extrabold uppercase tracking-wide text-white transition hover:brightness-95"
				>
					Solicitar Consultoria
				</a>
			</div>

			<div class="relative mx-auto w-full max-w-2xl">
				<div class="pointer-events-none absolute -left-7 top-4 h-16 w-24 rounded-[60%_40%_45%_55%] bg-ceja-blue/15"></div>
				<div class="pointer-events-none absolute right-2 bottom-10 h-14 w-28 rounded-[35%_65%_50%_50%] bg-ceja-orange/45"></div>

				<div class="overflow-hidden rounded-[2.8rem] border-8 border-white bg-white shadow-[0_30px_60px_-28px_rgba(10,29,55,0.45)]">
					<Image
						src={heroEstagio}
						alt="Equipe corporativa diversa colaborando em escritório moderno"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						loading="eager"
						fetchpriority="high"
						class="h-[440px] w-full object-cover"
					/>
				</div>

				<div class="absolute -bottom-9 left-4 hidden h-40 w-52 overflow-hidden rounded-[1.6rem] border-4 border-white bg-white shadow-xl sm:block">
					<Image
						src={corporativoEstagio}
						alt="Profissionais em reunião de alinhamento com consultoria CEJA"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						class="h-full w-full object-cover"
					/>
				</div>

				<div class="absolute -right-5 top-12 hidden h-28 w-40 overflow-hidden rounded-[1.4rem] border-4 border-white bg-white shadow-lg lg:block">
					<Image
						src={heroPcd}
						alt="Profissional PCD integrado ao time em ambiente corporativo"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						class="h-full w-full object-cover"
					/>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-ceja-surface py-20">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Por que o CEJA?</p>
				<h2 class="mt-3 text-3xl font-bold text-ceja-blue-dark sm:text-4xl">Benefícios para Sua Operação e para Sua Marca</h2>
			</div>

			<div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				{
					empresasData.beneficios.map((beneficio, index) => (
						<article class="rounded-[2rem] border border-gray-100 bg-white p-7 shadow-sm">
							<div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue">
								{index === 0 && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
										<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
										<circle cx="9" cy="7" r="4" />
										<path d="M23 21v-2a4 4 0 0 0-3-3.87" />
										<path d="M16 3.13a4 4 0 0 1 0 7.75" />
									</svg>
								)}
								{index === 1 && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
										<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
										<circle cx="9" cy="7" r="4" />
										<path d="M19 8v2M19 12v-2" />
									</svg>
								)}
								{index === 2 && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
										<path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Z" />
										<path d="M12 6v6l4 2" />
									</svg>
								)}
								{index === 3 && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
										<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
										<path d="M22 4L12 14.01l-3-3" />
									</svg>
								)}
								{index === 4 && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
										<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
									</svg>
								)}
							</div>
							<h3 class="mt-5 text-2xl font-bold text-ceja-blue-dark">{beneficio.titulo}</h3>
							<p class="mt-3 text-sm leading-relaxed text-ceja-muted">{beneficio.descricao}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-white py-20">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Fluxo de Atendimento</p>
				<h2 class="mt-3 text-3xl font-bold text-ceja-blue-dark sm:text-4xl">Um Processo Simples, Técnico e Previsível</h2>
			</div>

			<div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
				{
					empresasData.fluxoAtendimento.map((etapa, index) => (
						<div class="relative rounded-3xl border border-gray-100 bg-white p-6 shadow-sm">
							<span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-ceja-blue-dark text-sm font-bold text-white">
								{index + 1}
							</span>
							<p class="mt-4 text-lg font-bold text-ceja-blue-dark">{etapa}</p>
							{index < empresasData.fluxoAtendimento.length - 1 && (
								<div class="pointer-events-none absolute -right-3 top-1/2 hidden h-3 w-6 -translate-y-1/2 rounded-full bg-ceja-orange/80 xl:block"></div>
							)}
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-ceja-surface py-20">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="rounded-[2rem] border border-ceja-blue/20 bg-white p-8 shadow-sm sm:p-10">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Visão Estratégica</p>
				<h2 class="mt-3 text-3xl font-black text-ceja-blue-dark sm:text-4xl">Slogan Corporativo</h2>
				<blockquote class="mt-6 border-l-4 border-ceja-orange pl-6">
					<p class="text-2xl font-bold tracking-tight text-ceja-blue-dark md:text-3xl">
						"Formando talentos. Fortalecendo organizações. Transformando realidades."
					</p>
				</blockquote>
				<p class="mt-6 max-w-4xl text-base leading-relaxed text-ceja-muted">
					Acreditamos que a aprendizagem profissional vai muito além do cumprimento de uma obrigação legal. Ela representa uma oportunidade concreta de desenvolver talentos, fortalecer organizações e transformar realidades. Ao conectar jovens ao mundo do trabalho por meio de uma formação estruturada, promovemos inclusão, qualificação profissional e desenvolvimento sustentável, gerando benefícios para os participantes, para as empresas e para a sociedade.
				</p>
			</div>
		</div>
	</section>

	<section class="bg-white py-20">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="grid gap-12 lg:grid-cols-2 lg:items-center">
				<div class="rounded-[2.5rem] bg-gradient-to-br from-ceja-blue-dark to-ceja-blue p-8 text-white shadow-xl sm:p-10">
					<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-yellow">Compromisso Institucional</p>
					<p class="mt-6 text-xl font-medium leading-relaxed italic text-ceja-blue-light">
						"A aprendizagem profissional não forma apenas trabalhadores. Forma talentos, fortalece organizações e transforma realidades."
					</p>
				</div>
				<div class="rounded-[2.5rem] bg-gradient-to-br from-ceja-orange to-ceja-orange/90 p-8 text-white shadow-xl sm:p-10">
					<p class="text-sm font-semibold uppercase tracking-[0.2em] text-white/85">Foco no Amanhã</p>
					<p class="mt-6 text-xl font-medium leading-relaxed italic text-white">
						"Investir em jovens aprendizes é construir hoje os profissionais que sua empresa precisará amanhã."
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-ceja-surface py-20">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="rounded-[2rem] border border-ceja-blue/20 bg-white p-8 shadow-sm sm:p-10">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Diferencial Técnico</p>
				<h2 class="mt-3 text-3xl font-black text-ceja-blue-dark sm:text-4xl">CEJA Brasil é Entidade Qualificadora</h2>
				<p class="mt-5 max-w-4xl text-base leading-relaxed text-ceja-muted">
					Esse reconhecimento técnico reforça nossa autoridade para estruturar programas de aprendizagem com cumprimento legal, trilhas formativas e acompanhamento contínuo, reduzindo riscos trabalhistas e fortalecendo a governança da sua empresa.
				</p>
			</div>
		</div>
	</section>

	<section id="consultoria-corporativa" class="bg-ceja-blue-dark py-16">
		<div class="mx-auto flex w-full max-w-7xl flex-col items-start justify-between gap-6 px-4 sm:px-6 lg:flex-row lg:items-center lg:px-8">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-yellow">CTA Corporativo</p>
				<h2 class="mt-2 text-3xl font-black text-white sm:text-4xl">Pronto para Transformar Sua Equipe?</h2>
			</div>
			<a
				href="https://wa.me/5511945957746?text=Ol%C3%A1!%20Gostaria%20de%20solicitar%20uma%20consultoria%20corporativa%20com%20o%20CEJA%20Brasil."
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex rounded-full bg-ceja-orange px-8 py-4 text-sm font-extrabold uppercase tracking-wide text-white transition hover:brightness-95"
			>
				SOLICITAR CONSULTORIA CORPORATIVA
			</a>
		</div>
	</section>
</Layout>
