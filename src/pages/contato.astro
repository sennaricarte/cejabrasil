---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Contato CEJA Brasil | Programas de Aprendizagem, Estágio e Inclusão PCD"
	description="Fale com o CEJA Brasil sobre Programas de Aprendizagem, Estágio e Inclusão PCD. Atendimento para empresas, escolas e parceiros institucionais."
	keywords="contato ceja brasil, contratar aprendiz, contratar estagiário, inclusão pcd, parceria institucional"
>
	<section class="bg-ceja-surface py-20">
		<div class="mx-auto grid w-full max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
			<div>
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Contato CEJA Brasil</p>
				<h1 class="mt-4 text-4xl font-extrabold leading-tight text-ceja-blue-dark sm:text-5xl">
					Estamos prontos para ajudar sua empresa
				</h1>
				<p class="mt-5 max-w-2xl text-lg leading-relaxed text-ceja-muted">
					Entre em contato para dúvidas sobre Programas de Aprendizagem, Estágio ou Inclusão PCD.
				</p>

				<div class="mt-8 space-y-6">
					<div>
						<h2 class="text-lg font-bold text-ceja-dark">Unidades</h2>
						<div class="mt-4 grid gap-4">
							<article class="rounded-2xl border border-ceja-blue/20 bg-white p-5">
								<p class="text-sm font-semibold text-ceja-blue">Matriz (Administrativo)</p>
								<div class="mt-3 space-y-2 text-sm text-ceja-muted">
									<p class="flex items-center gap-3">
										<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-ceja-blue" aria-hidden="true">
											<path d="M1.5 6.75A2.25 2.25 0 0 1 3.75 4.5h16.5a2.25 2.25 0 0 1 2.25 2.25v10.5a2.25 2.25 0 0 1-2.25 2.25H3.75A2.25 2.25 0 0 1 1.5 17.25V6.75Zm2.7-.75 7.34 5.24a.75.75 0 0 0 .92 0L19.8 6H4.2Z" />
										</svg>
										<span><strong>E-mail:</strong> atendimento@cejabrasil.org.br</span>
									</p>
									<p class="flex items-center gap-3">
										<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-ceja-blue" aria-hidden="true">
											<path d="M16.75 13.96c.25.13.55.06.72-.16l1.63-2.06a.75.75 0 0 0-.09-1.04l-1.6-1.39a.75.75 0 0 1-.2-.81l.64-1.95a.75.75 0 0 0-.43-.94l-2.03-.82a.75.75 0 0 0-.9.29l-1.22 1.74a.75.75 0 0 1-.76.3l-2.1-.34a.75.75 0 0 0-.84.58l-.4 2.13a.75.75 0 0 1-.56.59l-2.08.53a.75.75 0 0 0-.54.79l.2 2.18a.75.75 0 0 1-.38.73l-1.88 1.1a.75.75 0 0 0-.25 1l1.08 1.84a.75.75 0 0 0 .74.36l2.13-.3a.75.75 0 0 1 .74.32l1.2 1.7a.75.75 0 0 0 .9.28l2.03-.82a.75.75 0 0 0 .43-.93l-.64-1.95a.75.75 0 0 1 .2-.82l1.6-1.38a.75.75 0 0 0 .08-1.05l-1.63-2.05a.59.59 0 0 1-.04-.66l.95-1.71a.75.75 0 0 1 1.05-.3l2.03 1.17c.25.15.58.09.76-.13l1.4-1.78a.75.75 0 0 1 1.13-.04l1.57 1.6a.75.75 0 0 1 .02 1.04l-1.52 1.72a.75.75 0 0 0-.13.77l1.02 2.04Z" />
										</svg>
										<span>
											<strong>WhatsApp:</strong>
											<a class="text-ceja-blue underline-offset-2 hover:underline" href="https://wa.me/5511945957746" target="_blank" rel="noopener noreferrer">(11) 94595-7746</a>
											<em class="ml-1 text-ceja-muted/80">(Somente mensagens)</em>
										</span>
									</p>
								</div>
							</article>

							<article class="rounded-2xl border border-ceja-blue/20 bg-white p-5">
								<p class="text-sm font-semibold text-ceja-blue">Unidade Centro – SP</p>
								<div class="mt-3 space-y-2 text-sm text-ceja-muted">
									<p class="flex items-start gap-3">
										<svg viewBox="0 0 24 24" fill="currentColor" class="mt-0.5 h-5 w-5 text-ceja-blue" aria-hidden="true">
											<path d="M12 2.25a7.5 7.5 0 0 0-7.5 7.5c0 5.25 7.5 12 7.5 12s7.5-6.75 7.5-12a7.5 7.5 0 0 0-7.5-7.5Zm0 10.5a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z" />
										</svg>
										<span><strong>Endereço:</strong> Rua Conselheiro Crispiniano, 105 – 3º Andar – Sala 32, Centro, São Paulo - SP</span>
									</p>
									<p class="flex items-center gap-3">
										<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-ceja-blue" aria-hidden="true">
											<path d="M2.25 4.5A2.25 2.25 0 0 1 4.5 2.25h2.41c1.03 0 1.94.7 2.2 1.7l.66 2.49a2.25 2.25 0 0 1-.93 2.46l-1.27.85a11.04 11.04 0 0 0 5.68 5.68l.85-1.27a2.25 2.25 0 0 1 2.46-.93l2.49.66a2.25 2.25 0 0 1 1.7 2.2v2.41a2.25 2.25 0 0 1-2.25 2.25h-1.5C8.77 22.5 1.5 15.23 1.5 6v-1.5Z" />
										</svg>
										<span><strong>Telefone Fixo:</strong> (11) 3214-4923</span>
									</p>
								</div>
							</article>
						</div>
					</div>

					<div class="rounded-2xl border border-ceja-green/50 bg-ceja-green/10 p-5">
						<h2 class="text-lg font-bold text-ceja-dark">Nossos Contatos</h2>
						<ul class="mt-3 space-y-2 text-sm text-ceja-muted">
							<li><strong>Telefone fixo:</strong> (11) 3214-4923</li>
							<li>
								<strong>WhatsApp Suporte 1:</strong>
								<a class="text-ceja-blue underline-offset-2 hover:underline" href="https://wa.me/5511941737398" target="_blank" rel="noopener noreferrer">(11) 94173-7398</a>
							</li>
							<li>
								<strong>WhatsApp Suporte 2:</strong>
								<a class="text-ceja-blue underline-offset-2 hover:underline" href="https://wa.me/5511954954941" target="_blank" rel="noopener noreferrer">(11) 95495-4941</a>
							</li>
						</ul>
					</div>

					<div>
						<p class="text-sm font-semibold text-ceja-dark">Siga-nos para acompanhar o impacto social</p>
						<div class="mt-3 flex items-center gap-3">
							<a href="#" aria-label="Instagram CEJA Brasil" class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue transition hover:bg-ceja-blue hover:text-white">
								<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
									<path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5a4.25 4.25 0 0 0 4.25 4.25h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5a4.25 4.25 0 0 0-4.25-4.25h-8.5Zm8.75 1.75a1 1 0 1 1 0 2 1 1 0 0 1 0-2ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Z" />
								</svg>
							</a>
							<a href="#" aria-label="LinkedIn CEJA Brasil" class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue transition hover:bg-ceja-blue hover:text-white">
								<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
									<path d="M6.5 8a1.75 1.75 0 1 1 0-3.5A1.75 1.75 0 0 1 6.5 8ZM5 9.5h3v9H5v-9Zm5 0h2.9v1.3h.04c.4-.76 1.4-1.55 2.86-1.55 3.06 0 3.62 2.01 3.62 4.63v4.62h-3v-4.1c0-.98-.02-2.23-1.36-2.23-1.36 0-1.56 1.06-1.56 2.16v4.17h-3v-9Z" />
								</svg>
							</a>
							<a href="#" aria-label="Facebook CEJA Brasil" class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue transition hover:bg-ceja-blue hover:text-white">
								<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
									<path d="M13.5 9H16V6h-2.5A4.5 4.5 0 0 0 9 10.5V13H6v3h3v6h3v-6h3l1-3h-4v-2.5A1.5 1.5 0 0 1 13.5 9Z" />
								</svg>
							</a>
						</div>
					</div>
				</div>
			</div>

			<div class="rounded-3xl bg-white p-8 shadow-[0_18px_40px_-24px_rgba(15,23,42,0.45)] sm:p-10">
				<h2 class="text-2xl font-bold text-ceja-dark">Envie sua mensagem</h2>
				<form class="mt-6 grid gap-4" action="#" method="post">
					<label class="text-sm font-medium text-ceja-muted">
						Nome Completo
						<input type="text" name="nome-completo" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 focus:border-ceja-blue focus:outline-none" />
					</label>
					<label class="text-sm font-medium text-ceja-muted">
						E-mail Corporativo
						<input type="email" name="email-corporativo" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 focus:border-ceja-blue focus:outline-none" />
					</label>
					<label class="text-sm font-medium text-ceja-muted">
						Telefone
						<input type="tel" name="telefone" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 focus:border-ceja-blue focus:outline-none" />
					</label>
					<label class="text-sm font-medium text-ceja-muted">
						Empresa
						<input type="text" name="empresa" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 focus:border-ceja-blue focus:outline-none" />
					</label>
					<label class="text-sm font-medium text-ceja-muted">
						Assunto
						<select name="assunto" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 focus:border-ceja-blue focus:outline-none">
							<option>Contratar Aprendiz</option>
							<option>Contratar Estagiário</option>
							<option>Inclusão PCD</option>
							<option>Outros</option>
						</select>
					</label>
					<label class="text-sm font-medium text-ceja-muted">
						Mensagem
						<textarea name="mensagem" rows="5" class="mt-1 w-full rounded-2xl border border-slate-300 px-4 py-3 focus:border-ceja-blue focus:outline-none"></textarea>
					</label>

					<button
						type="submit"
						class="mt-2 inline-flex w-fit rounded-full bg-ceja-orange px-8 py-3 text-sm font-extrabold uppercase tracking-wide text-white transition hover:brightness-105"
					>
						Enviar Mensagem
					</button>
				</form>
			</div>
		</div>
	</section>

	<section class="bg-white pb-20">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="overflow-hidden rounded-3xl border-4 border-ceja-blue/30 bg-white p-2 shadow-[0_16px_38px_-24px_rgba(15,23,42,0.4)]">
				<iframe
					title="Mapa CEJA Brasil"
					src="https://www.google.com/maps?q=Rua+Conselheiro+Crispiniano,+105,+São+Paulo,+SP&output=embed"
					class="h-[420px] w-full rounded-2xl border-0"
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
				></iframe>
			</div>
		</div>
	</section>
</Layout>
