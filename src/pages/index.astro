---
import { Image } from 'astro:assets';
import CourseCard from '../components/CourseCard.astro';
import CertificacoesSection from '../components/CertificacoesSection.astro';
import NotaFiscalPaulistaSection from '../components/NotaFiscalPaulistaSection.astro';
import courses from '../data/courses.json';
import Layout from '../layouts/Layout.astro';
import { courseCoverImages } from '../utils/courseCoverImages';
import heroJovemAprendiz from '../assets/jovem-aprendiz/hero-jovem-aprendiz.png';
import heroEstagio from '../assets/estagio/hero-estagio.jpg';
import parceriaEscolaConsultor from '../assets/estagio/parceria-escola-consultor.jpg';
import heroPcd from '../assets/pcd/hero-pcd-inclusao.png';
import heroServicosEducacionais from '../assets/cursos/hero-servicos-educacionais.png';
import servicosDestaque from '../data/servicos-destaque.json';

const servicoImageMap = {
	aprendiz: heroJovemAprendiz,
	pcd: heroPcd,
	educacao: heroServicosEducacionais,
};

---

<Layout>
	<section class="bg-white py-20">
		<div class="mx-auto grid w-full max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:gap-16 lg:px-8">
			<div>
				<h1 class="max-w-2xl text-4xl font-black leading-tight text-ceja-blue-dark sm:text-5xl lg:text-6xl">
					Contrate Jovens Aprendizes, Estagiários e PCDs com Segurança Jurídica
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-relaxed text-ceja-muted">
					O CEJA Brasil e a ponte entre empresas e talentos, conectando sua organizacao aos melhores perfis
					com acompanhamento tecnico especializado e foco em resultado.
				</p>
				<div class="mt-9 flex flex-wrap items-center gap-4">
					<a
						href="/jovem-aprendiz"
						class="inline-flex rounded-full bg-ceja-orange-a11y px-7 py-3 text-base font-semibold text-white transition hover:brightness-105"
					>
						Quero Contratar
					</a>
					<a
						href="https://wa.me/5511945957746?text=Ol%C3%A1!%20Gostaria%20de%20falar%20com%20um%20consultor%20do%20CEJA%20Brasil."
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex rounded-full border-2 border-ceja-blue px-7 py-3 text-base font-semibold text-ceja-blue transition hover:bg-ceja-blue hover:text-white"
					>
						Falar com Consultor
					</a>
				</div>
			</div>

			<div class="relative mx-auto w-full max-w-2xl">
				<div class="pointer-events-none absolute -left-9 top-8 h-20 w-28 rounded-[55%_45%_65%_35%] bg-ceja-blue/18"></div>
				<div class="pointer-events-none absolute right-3 top-5 h-24 w-24 rounded-[40%_60%_50%_50%] bg-ceja-orange/40"></div>
				<div class="pointer-events-none absolute -right-8 bottom-20 h-14 w-32 rounded-[65%_35%_55%_45%] bg-ceja-blue/20"></div>
				<div class="pointer-events-none absolute left-10 -bottom-5 h-16 w-16 rounded-full bg-ceja-orange/45"></div>
				<div class="pointer-events-none absolute right-20 -bottom-2 h-12 w-20 rounded-[50%_50%_35%_65%] bg-ceja-blue/16"></div>

				<div class="overflow-hidden rounded-[2.8rem] border-8 border-white bg-white shadow-[0_30px_60px_-28px_rgba(15,74,110,0.28)]">
					<Image
						src={heroEstagio}
						alt="Jovem profissional sorrindo enquanto trabalha em um escritório moderno"
						width={900}
						height={600}
						densities={[1, 2]}
						format="webp"
						quality="mid"
						loading="eager"
						fetchpriority="high"
						class="h-[460px] w-full object-cover"
					/>
				</div>

				<div class="absolute -bottom-10 left-4 hidden w-52 overflow-hidden rounded-[1.8rem] border-4 border-white bg-white shadow-2xl sm:block">
					<Image
						src={parceriaEscolaConsultor}
						alt="Aperto de mão entre consultor e gestor de RH durante integração corporativa"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						class="h-40 w-full object-cover"
					/>
				</div>
			</div>
		</div>
	</section>

	<section id="servicos-destaque" class="relative overflow-hidden bg-ceja-header py-24 sm:py-28">
		<div class="pointer-events-none absolute -left-16 top-10 h-40 w-40 rounded-full bg-white/10"></div>
		<div class="pointer-events-none absolute -right-10 bottom-8 h-32 w-32 rounded-full bg-ceja-orange/25"></div>
		<div class="pointer-events-none absolute left-1/3 top-1/2 h-20 w-48 rounded-[60%_40%_50%_50%] bg-ceja-green/20"></div>

		<div class="relative mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-white">
					{servicosDestaque.titulo}
				</p>
				<h2 class="mt-4 text-3xl font-black text-white sm:text-4xl lg:text-5xl">
					{servicosDestaque.subtitulo}
				</h2>
				<p class="mt-5 text-lg leading-relaxed text-ceja-blue-light">
					{servicosDestaque.intro}
				</p>
			</div>

			<div class="mt-14 grid gap-8 lg:grid-cols-3">
				{
					servicosDestaque.servicos.map((servico, index) => (
						<article class="group flex flex-col overflow-hidden rounded-[2rem] bg-white shadow-[0_24px_50px_-24px_rgba(0,0,0,0.35)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_32px_60px_-20px_rgba(0,0,0,0.4)]">
							<div class="relative overflow-hidden">
								<span
									class:list={[
										'absolute left-4 top-4 z-10 rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wide text-white',
										index === 0 && 'bg-ceja-blue',
										index === 1 && 'bg-ceja-green-a11y',
										index === 2 && 'bg-ceja-orange-a11y',
									]}
								>
									{servico.badge}
								</span>
								<Image
									src={servicoImageMap[servico.imageKey as keyof typeof servicoImageMap]}
									alt={`Imagem ilustrativa de inclusão no trabalho — ${servico.titulo}`}
									width={480}
									height={320}
									densities={[1, 2]}
									format="webp"
									quality="mid"
									class="h-56 w-full object-cover transition duration-500 group-hover:scale-105"
								/>
								<div class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-ceja-blue-dark/50 to-transparent"></div>
							</div>

							<div class="flex flex-1 flex-col p-7 sm:p-8">
								<h3 class="text-2xl font-bold leading-tight text-ceja-blue-dark">{servico.titulo}</h3>
								<p class="mt-4 flex-1 text-base leading-relaxed text-ceja-muted">{servico.descricao}</p>
								<a
									href={servico.href}
									class:list={[
										'mt-7 inline-flex w-fit items-center gap-2 rounded-full px-6 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:brightness-110',
										index === 0 && 'bg-ceja-blue',
										index === 1 && 'bg-ceja-green-a11y',
										index === 2 && 'bg-ceja-orange-a11y',
									]}
									aria-label={`${servico.cta} — ${servico.titulo}`}
								>
									{servico.cta}
									<span aria-hidden="true">→</span>
								</a>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="mt-20 mb-10 bg-white py-20 sm:py-24">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-2xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue-a11y">Nossas Trilhas de Aprendizagem</p>
				<h2 class="mt-3 text-3xl font-bold text-ceja-dark sm:text-4xl">Formação Prática para Gerar Talentos Prontos para o Mercado</h2>
			</div>

			<div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
				{
					courses.map((course) => (
						<CourseCard
							title={course.title}
							hours={course.hours}
							description={course.description}
							imageKey={course.imageKey}
							detailHref={'slug' in course && course.slug ? `/cursos/${course.slug}` : '#'}
							coverImage={'slug' in course && course.slug ? courseCoverImages[course.slug] : undefined}
						/>
					))
				}
			</div>
		</div>
	</section>

	<CertificacoesSection />

	<NotaFiscalPaulistaSection />

	<section class="bg-white py-20 sm:py-24">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue-a11y">Por que contratar através do CEJA?</p>
				<h2 class="mt-3 text-3xl font-bold text-ceja-dark sm:text-4xl">Mais Segurança, Eficiência e Impacto para a Sua Empresa</h2>
			</div>

			<div class="mt-12 grid gap-6 md:grid-cols-3">
				<article class="rounded-[2rem] bg-white p-8 text-center shadow-[0_12px_30px_-18px_rgba(15,23,42,0.35)]">
					<div class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue-a11y">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-9 w-9" aria-hidden="true">
							<path d="M12 3l7 3v6c0 4.5-2.9 7.8-7 9-4.1-1.2-7-4.5-7-9V6l7-3Z" />
							<path d="m9.5 12 1.8 1.8L15 10.2" />
						</svg>
					</div>
					<h3 class="mt-5 text-xl font-bold text-ceja-dark">Segurança Jurídica Total</h3>
					<p class="mt-3 text-sm leading-relaxed text-ceja-muted">
						Atuamos em conformidade com a Lei da Aprendizagem para garantir contratações seguras, auditáveis e alinhadas às exigências legais.
					</p>
				</article>

				<article class="rounded-[2rem] bg-white p-8 text-center shadow-[0_12px_30px_-18px_rgba(15,23,42,0.35)]">
					<div class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue-a11y">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-9 w-9" aria-hidden="true">
							<rect x="3" y="4" width="18" height="16" rx="3" />
							<path d="M7 9h10M7 13h6M7 17h4" />
						</svg>
					</div>
					<h3 class="mt-5 text-xl font-bold text-ceja-dark">Gestão de Ponta a Ponta</h3>
					<p class="mt-3 text-sm leading-relaxed text-ceja-muted">
						Cuidamos do recrutamento, da seleção e do acompanhamento pedagógico para manter a evolução contínua dos participantes.
					</p>
				</article>

				<article class="rounded-[2rem] bg-white p-8 text-center shadow-[0_12px_30px_-18px_rgba(15,23,42,0.35)]">
					<div class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue-a11y">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-9 w-9" aria-hidden="true">
							<path d="M12 21a8 8 0 1 0-8-8h3l-4 5-4-5h3a13 13 0 1 1 13 13Z" />
							<path d="M12 8v4l3 2" />
						</svg>
					</div>
					<h3 class="mt-5 text-xl font-bold text-ceja-dark">Impacto Social Real</h3>
					<p class="mt-3 text-sm leading-relaxed text-ceja-muted">
						Promovemos a inclusão de jovens e PCDs com oportunidades estruturadas, fortalecendo diversidade e transformação social.
					</p>
				</article>
			</div>

			<div class="mt-12 text-center">
				<p class="mx-auto max-w-3xl text-lg text-ceja-muted">
					Transforme sua obrigação legal em vantagem competitiva com uma operação completa, humana e orientada por resultados.
				</p>
				<a
					href="https://wa.me/5511945957746?text=Ol%C3%A1!%20Gostaria%20de%20solicitar%20uma%20proposta%20para%20contrata%C3%A7%C3%A3o%20de%20Jovem%20Aprendiz%20ou%20PCD."
					target="_blank"
					rel="noopener noreferrer"
					class="mt-7 inline-flex rounded-full bg-ceja-orange-a11y px-10 py-5 text-base font-extrabold uppercase tracking-wide text-white shadow-[0_12px_30px_-14px_rgba(232,107,42,0.45)] transition hover:brightness-95"
				>
					SOLICITAR UMA PROPOSTA AGORA
				</a>
			</div>
		</div>
	</section>
</Layout>
