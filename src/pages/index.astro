---
import { Image } from 'astro:assets';
import CourseCard from '../components/CourseCard.astro';
import courses from '../data/courses.json';
import Layout from '../layouts/Layout.astro';
import heroEstagio from '../assets/estagio/hero-estagio.jpg';
import parceriaEscolaConsultor from '../assets/estagio/parceria-escola-consultor.jpg';
import adm6 from '../assets/courses/adm6.jpg';
import adm4 from '../assets/courses/adm4.jpg';
import varejo6 from '../assets/courses/varejo6.jpg';
import contact4 from '../assets/courses/contact4.jpg';
import contact6 from '../assets/courses/contact6.jpg';
import teleprocess4h48 from '../assets/courses/teleprocess4h48.jpg';
import producao6 from '../assets/courses/producao6.jpg';
import saude6 from '../assets/courses/saude6.jpg';
import alimentacao6 from '../assets/courses/alimentacao6.jpg';
import manutencao4 from '../assets/courses/manutencao4.jpg';
import frentista4 from '../assets/courses/frentista4.jpg';
import telecom4h48 from '../assets/courses/telecom4h48.jpg';
import jardineiro4 from '../assets/courses/jardineiro4.jpg';

const courseImageMap = {
	adm6,
	adm4,
	varejo6,
	contact4,
	contact6,
	teleprocess4h48,
	producao6,
	saude6,
	alimentacao6,
	manutencao4,
	frentista4,
	telecom4h48,
	jardineiro4,
};
---

<Layout>
	<section class="bg-white py-20">
		<div class="mx-auto grid w-full max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:gap-16 lg:px-8">
			<div>
				<h1 class="max-w-2xl text-4xl font-black leading-tight text-[#0a1d37] sm:text-5xl lg:text-6xl">
					Contrate Jovens Aprendizes, Estagiários e PCDs com Segurança Jurídica
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600">
					O CEJA Brasil e a ponte entre empresas e talentos, conectando sua organizacao aos melhores perfis
					com acompanhamento tecnico especializado e foco em resultado.
				</p>
				<div class="mt-9 flex flex-wrap items-center gap-4">
					<a
						href="#"
						class="inline-flex rounded-full bg-ceja-yellow px-7 py-3 text-base font-semibold text-black transition hover:brightness-95"
					>
						Quero Contratar
					</a>
					<a
						href="#"
						class="inline-flex rounded-full border-2 border-ceja-blue px-7 py-3 text-base font-semibold text-ceja-blue transition hover:bg-ceja-blue hover:text-white"
					>
						Falar com Consultor
					</a>
				</div>
			</div>

			<div class="relative mx-auto w-full max-w-2xl">
				<div class="pointer-events-none absolute -left-9 top-8 h-20 w-28 rounded-[55%_45%_65%_35%] bg-ceja-blue/18"></div>
				<div class="pointer-events-none absolute right-3 top-5 h-24 w-24 rounded-[40%_60%_50%_50%] bg-[#FDCB08]/40"></div>
				<div class="pointer-events-none absolute -right-8 bottom-20 h-14 w-32 rounded-[65%_35%_55%_45%] bg-ceja-blue/20"></div>
				<div class="pointer-events-none absolute left-10 -bottom-5 h-16 w-16 rounded-full bg-[#FDCB08]/45"></div>
				<div class="pointer-events-none absolute right-20 -bottom-2 h-12 w-20 rounded-[50%_50%_35%_65%] bg-ceja-blue/16"></div>

				<div class="overflow-hidden rounded-[2.8rem] border-8 border-white bg-white shadow-[0_30px_60px_-28px_rgba(10,29,55,0.45)]">
					<Image
						src={heroEstagio}
						alt="Jovem profissional sorrindo enquanto trabalha em um escritório moderno"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						class="h-[460px] w-full object-cover"
					/>
				</div>

				<div class="absolute -bottom-10 left-4 hidden w-52 overflow-hidden rounded-[1.8rem] border-4 border-white bg-white shadow-2xl sm:block">
					<Image
						src={parceriaEscolaConsultor}
						alt="Aperto de mão entre consultor e gestor de RH durante integração corporativa"
						width={1400}
						height={933}
						format="webp"
						quality="mid"
						class="h-40 w-full object-cover"
					/>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-20 sm:py-24">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="max-w-2xl">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Nossas Soluções</p>
				<h2 class="mt-3 text-3xl font-bold text-ceja-dark sm:text-4xl">Programas sob medida para contratar com impacto</h2>
			</div>

			<div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
				<article class="rounded-[2rem] bg-white p-7 shadow-[0_12px_30px_-18px_rgba(15,23,42,0.35)]">
					<div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
							<path d="M12 14a5 5 0 1 0 0-10 5 5 0 0 0 0 10Z" />
							<path d="M4 20a8 8 0 0 1 16 0" />
						</svg>
					</div>
					<h3 class="mt-5 text-xl font-semibold text-ceja-dark">Programa Jovem Aprendiz</h3>
					<p class="mt-3 text-sm leading-relaxed text-slate-600">
						Captação, seleção e acompanhamento de jovens talentos com conformidade legal e foco em evolução.
					</p>
					<a href="#" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-ceja-blue transition hover:text-ceja-yellow">
						Ver detalhes
						<span aria-hidden="true">→</span>
					</a>
				</article>

				<article class="rounded-[2rem] bg-white p-7 shadow-[0_12px_30px_-18px_rgba(15,23,42,0.35)]">
					<div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
							<path d="M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v11a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 17.5v-11Z" />
							<path d="M8 9.5h8M8 12h8M8 14.5h5" />
						</svg>
					</div>
					<h3 class="mt-5 text-xl font-semibold text-ceja-dark">Estágio Supervisionado</h3>
					<p class="mt-3 text-sm leading-relaxed text-slate-600">
						Gestão completa do programa de estágio com processos ágeis, pedagógicos e alinhados ao seu negócio.
					</p>
					<a href="#" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-ceja-blue transition hover:text-ceja-yellow">
						Ver detalhes
						<span aria-hidden="true">→</span>
					</a>
				</article>

				<article class="rounded-[2rem] bg-white p-7 shadow-[0_12px_30px_-18px_rgba(15,23,42,0.35)]">
					<div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6" aria-hidden="true">
							<path d="M7 10V8a5 5 0 1 1 10 0v2" />
							<rect x="4" y="10" width="16" height="10" rx="2.5" />
							<path d="M12 13v4" />
						</svg>
					</div>
					<h3 class="mt-5 text-xl font-semibold text-ceja-dark">Inclusão de PCD</h3>
					<p class="mt-3 text-sm leading-relaxed text-slate-600">
						Recrutamento inclusivo com suporte técnico para criar ambientes acessíveis e fortalecer a cultura da empresa.
					</p>
					<a href="#" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-ceja-blue transition hover:text-ceja-yellow">
						Ver detalhes
						<span aria-hidden="true">→</span>
					</a>
				</article>
			</div>
		</div>
	</section>

	<section class="mt-20 mb-10 bg-white py-20 sm:py-24">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-2xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Nossas Trilhas de Aprendizagem</p>
				<h2 class="mt-3 text-3xl font-bold text-ceja-dark sm:text-4xl">Formação prática para gerar talentos prontos para o mercado</h2>
			</div>

			<div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
				{
					courses.map((course) => (
						<CourseCard
							title={course.title}
							hours={course.hours}
							description={course.description}
							image={courseImageMap[course.imageKey as keyof typeof courseImageMap]}
						/>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-white py-20 sm:py-24">
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<p class="text-sm font-semibold uppercase tracking-[0.2em] text-ceja-blue">Por que contratar através do CEJA?</p>
				<h2 class="mt-3 text-3xl font-bold text-ceja-dark sm:text-4xl">Mais segurança, eficiência e impacto para a sua empresa</h2>
			</div>

			<div class="mt-12 grid gap-6 md:grid-cols-3">
				<article class="rounded-[2rem] bg-white p-8 text-center shadow-[0_12px_30px_-18px_rgba(15,23,42,0.35)]">
					<div class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-9 w-9" aria-hidden="true">
							<path d="M12 3l7 3v6c0 4.5-2.9 7.8-7 9-4.1-1.2-7-4.5-7-9V6l7-3Z" />
							<path d="m9.5 12 1.8 1.8L15 10.2" />
						</svg>
					</div>
					<h3 class="mt-5 text-xl font-bold text-ceja-dark">Segurança Jurídica Total</h3>
					<p class="mt-3 text-sm leading-relaxed text-slate-600">
						Atuamos em conformidade com a Lei da Aprendizagem para garantir contratações seguras, auditáveis e alinhadas às exigências legais.
					</p>
				</article>

				<article class="rounded-[2rem] bg-white p-8 text-center shadow-[0_12px_30px_-18px_rgba(15,23,42,0.35)]">
					<div class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-9 w-9" aria-hidden="true">
							<rect x="3" y="4" width="18" height="16" rx="3" />
							<path d="M7 9h10M7 13h6M7 17h4" />
						</svg>
					</div>
					<h3 class="mt-5 text-xl font-bold text-ceja-dark">Gestão de Ponta a Ponta</h3>
					<p class="mt-3 text-sm leading-relaxed text-slate-600">
						Cuidamos do recrutamento, da seleção e do acompanhamento pedagógico para manter a evolução contínua dos participantes.
					</p>
				</article>

				<article class="rounded-[2rem] bg-white p-8 text-center shadow-[0_12px_30px_-18px_rgba(15,23,42,0.35)]">
					<div class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-ceja-blue/10 text-ceja-blue">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-9 w-9" aria-hidden="true">
							<path d="M12 21a8 8 0 1 0-8-8h3l-4 5-4-5h3a13 13 0 1 1 13 13Z" />
							<path d="M12 8v4l3 2" />
						</svg>
					</div>
					<h3 class="mt-5 text-xl font-bold text-ceja-dark">Impacto Social Real</h3>
					<p class="mt-3 text-sm leading-relaxed text-slate-600">
						Promovemos a inclusão de jovens e PCDs com oportunidades estruturadas, fortalecendo diversidade e transformação social.
					</p>
				</article>
			</div>

			<div class="mt-12 text-center">
				<p class="mx-auto max-w-3xl text-lg text-slate-600">
					Transforme sua obrigação legal em vantagem competitiva com uma operação completa, humana e orientada por resultados.
				</p>
				<a
					href="#"
					class="mt-7 inline-flex rounded-full bg-ceja-yellow px-10 py-5 text-base font-extrabold uppercase tracking-wide text-black shadow-[0_12px_30px_-14px_rgba(253,203,8,0.8)] transition hover:brightness-95"
				>
					SOLICITAR UMA PROPOSTA AGORA
				</a>
			</div>
		</div>
	</section>
</Layout>
